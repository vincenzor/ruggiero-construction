    color: var(--text-light);
  }

  .contact-form-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
  }

  .required {
    color: #e53e3e;
  }

  .form-group input,
  .form-group textarea {
